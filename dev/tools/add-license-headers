"""Bulk-add Apache 2.0 license headers to workload-resizer's source files.

Idempotent: detects any existing copyright/license block at the top of
each file and replaces it with the canonical full Apache 2.0
boilerplate. Files without any header get one inserted.

Run after creating new source files. Re-run safely after changing the
header template — the script normalizes whatever's there to the
current canonical form.

Scope:
- Go source under cmd/, internal/, test/
- Shell scripts under dev/tools/ and dev/ci/presubmits/
- YAML: .github/workflows/*.yml, dev/tools/.golangci.yml, docs/site/hugo.yaml
- Python: dev/tools/add-license-headers (this file)

For Go files, golangci-lint's `goheader` linter enforces the full
header on every CI run; this script is the bulk-add helper for the
file types that aren't lint-checked (shell + yaml + python).

Build-tagged Go files (e.g. test/e2e/*.go with `//go:build e2e`) need
the build tag to remain the FIRST thing in the file — block comments
disqualify build constraints. The script preserves the build-tag
prelude when present.
"""
import os
import re
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent.parent

# Body of the canonical header — used verbatim, just re-prefixed for
# each comment style. Keep in sync with dev/tools/.golangci.yml
# (goheader template), hack/boilerplate.go.txt, and the LICENSE appendix.
HEADER_BODY = """\
Copyright 2026 Google LLC

Licensed under the Apache License, Version 2.0 (the "License");
you may not use this file except in compliance with the License.
You may obtain a copy of the License at

    http://www.apache.org/licenses/LICENSE-2.0

Unless required by applicable law or agreed to in writing, software
distributed under the License is distributed on an "AS IS" BASIS,
WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
See the License for the specific language governing permissions and
limitations under the License."""


def comment_block(prefix: str) -> str:
    """Render the header with `prefix` (e.g. `// ` or `# `) on each line."""
    out = []
    bare = prefix.rstrip()
    for line in HEADER_BODY.split("\n"):
        out.append(f"{prefix}{line}" if line else bare)
    return "\n".join(out) + "\n"


GO_HEADER = comment_block("// ")
HASH_HEADER = comment_block("# ")

# Go block-comment form — what kubebuilder scaffolds and what we use for
# .go files. The `goheader` linter accepts either form.
GO_BLOCK_HEADER = "/*\n" + HEADER_BODY + "\n*/\n"

BUILD_TAG_RE = re.compile(r"^//\s*(go:build|\+build)\b")


def strip_existing_header_lines(lines, comment_prefix: str, start: int):
    """Skip a contiguous block of comment lines starting at `start` if it
    contains a copyright/license marker. Returns the index of the first
    line after the (optionally stripped) header + its trailing blank.
    """
    bare = comment_prefix.rstrip()
    end = start
    saw_marker = False
    while end < len(lines):
        line = lines[end]
        if line.startswith(comment_prefix) or line == bare:
            if any(m in line for m in ("Copyright", "Licensed under", "SPDX-License-Identifier")):
                saw_marker = True
            end += 1
            continue
        break
    if not saw_marker:
        return start
    if end < len(lines) and lines[end] == "":
        end += 1
    return end


def strip_existing_block_header(text: str, body_start: int) -> int:
    """If a /* ... */ block at body_start contains a copyright marker,
    return the index past it (including a trailing blank line).
    """
    if not text[body_start:].startswith("/*"):
        return body_start
    close = text.find("*/", body_start + 2)
    if close == -1:
        return body_start
    block = text[body_start:close + 2]
    if not any(m in block for m in ("Copyright", "Licensed under", "SPDX-License-Identifier")):
        return body_start
    end = close + 2
    # Strip one trailing newline + optional blank line.
    if end < len(text) and text[end] == "\n":
        end += 1
    if end < len(text) and text[end] == "\n":
        end += 1
    return end


def apply_go_header(path: Path) -> bool:
    """Apply Go block header, preserving any build-tag prelude (//go:build
    + // +build lines that must appear before package).
    """
    text = path.read_text()
    lines = text.split("\n")

    # Capture build-tag prelude (consecutive line comments matching the
    # build-tag pattern, plus the blank line that separates them).
    prelude_end = 0
    while prelude_end < len(lines) and BUILD_TAG_RE.match(lines[prelude_end]):
        prelude_end += 1
    if prelude_end > 0 and prelude_end < len(lines) and lines[prelude_end] == "":
        prelude_end += 1
    prelude = "\n".join(lines[:prelude_end])
    if prelude:
        prelude += "\n"
    rest_start = sum(len(l) + 1 for l in lines[:prelude_end])

    rest_after_existing = strip_existing_block_header(text, rest_start)
    # Also handle the case where an existing header was previously a line-
    # comment block (// Copyright ...) instead of a block comment.
    if rest_after_existing == rest_start:
        rest_lines = text[rest_start:].split("\n")
        line_skip = strip_existing_header_lines(rest_lines, "// ", 0)
        if line_skip > 0:
            rest_after_existing = rest_start + sum(len(l) + 1 for l in rest_lines[:line_skip])

    body = text[rest_after_existing:].lstrip("\n")
    new_text = prelude + GO_BLOCK_HEADER + "\n" + body
    if new_text == text:
        return False
    path.write_text(new_text)
    return True


def apply_hash_header(path: Path, has_shebang: bool) -> bool:
    text = path.read_text()
    lines = text.split("\n")

    shebang = ""
    start = 0
    if has_shebang and lines and lines[0].startswith("#!"):
        shebang = lines[0] + "\n"
        start = 1

    end = strip_existing_header_lines(lines, "# ", start)
    body = "\n".join(lines[end:])
    new_text = shebang + HASH_HEADER + "\n" + body.lstrip("\n")
    if new_text == text:
        return False
    path.write_text(new_text)
    return True


def is_executable_or_sh(p: Path) -> bool:
    return p.suffix == ".sh" or os.access(p, os.X_OK)


GO_DIRS = ("cmd", "internal", "test")


def main() -> None:
    counts = {"go": 0, "sh": 0, "yaml": 0, "py": 0}

    # Go: every hand-written .go under the package roots.
    for top in GO_DIRS:
        d = REPO_ROOT / top
        if not d.exists():
            continue
        for path in d.rglob("*.go"):
            if "/vendor/" in str(path):
                continue
            if path.name.startswith("zz_generated"):
                continue
            if apply_go_header(path):
                counts["go"] += 1
                print(f"go:   {path.relative_to(REPO_ROOT)}")

    # Shell: dev/tools + dev/ci/presubmits. Skip data files (.yml/.md/.py).
    for d in (REPO_ROOT / "dev/tools", REPO_ROOT / "dev/ci/presubmits"):
        if not d.exists():
            continue
        for path in d.iterdir():
            if not path.is_file():
                continue
            if path.suffix in (".yml", ".yaml", ".md", ".py"):
                continue
            if path.name == "common.sh" or is_executable_or_sh(path):
                if apply_hash_header(path, has_shebang=True):
                    counts["sh"] += 1
                    print(f"sh:   {path.relative_to(REPO_ROOT)}")

    # YAML: workflows, golangci-lint config, hugo config.
    yaml_files = [
        *list((REPO_ROOT / ".github/workflows").glob("*.yml")),
        REPO_ROOT / "dev/tools/.golangci.yml",
        REPO_ROOT / "docs/site/hugo.yaml",
    ]
    for path in yaml_files:
        if not path.exists():
            continue
        if apply_hash_header(path, has_shebang=False):
            counts["yaml"] += 1
            print(f"yaml: {path.relative_to(REPO_ROOT)}")

    # Python: scripts under dev/tools/ that have a shebang.
    py_files = [REPO_ROOT / "dev/tools/add-license-headers"]
    for path in py_files:
        if not path.exists():
            continue
        if apply_hash_header(path, has_shebang=True):
            counts["py"] += 1
            print(f"py:   {path.relative_to(REPO_ROOT)}")

    total = sum(counts.values())
    if total == 0:
        print("All files already carry the canonical header — nothing to do.")
    else:
        print()
        print(
            f"Updated headers — go: {counts['go']}, sh: {counts['sh']}, "
            f"yaml: {counts['yaml']}, py: {counts['py']}"
        )


if __name__ == "__main__":
    main()
