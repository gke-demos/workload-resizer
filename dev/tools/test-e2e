# Run the Kind + KWOK e2e suite. Wraps `make test-e2e` so this script
# composes the same way as the other dev/tools/* entries (single
# entrypoint, common.sh helpers, repo-root cwd).
#
# Needs Docker + kind ≥ 0.20 locally. To run against a non-Kind cluster,
# set USE_EXISTING_CLUSTER=true and MANAGER_IMAGE=<registry>/...:<tag> —
# see test/e2e/README.md.
set -euo pipefail
. "$(dirname "$0")/common.sh"
cd "$(repo_root)"

exec make test-e2e
