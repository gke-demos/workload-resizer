# Run unit + envtest suites with -race and atomic coverage.
#
# envtest needs a real kube-apiserver + etcd binary on disk;
# setup-envtest fetches them on demand. The Kind + KWOK e2e suite
# under test/e2e is *not* run here — use dev/tools/test-e2e for that
# (it's also wired into CI as a separate job).
#
# Outputs coverage.out at the repo root for the CI summary step.
set -euo pipefail
. "$(dirname "$0")/common.sh"
cd "$(repo_root)"

ensure_tool setup-envtest sigs.k8s.io/controller-runtime/tools/setup-envtest@latest

ENVTEST_K8S_VERSION="${ENVTEST_K8S_VERSION:-1.35.0}"
# Absolute --bin-dir so the returned ASSETS path is absolute too: envtest
# changes the process cwd during fork-and-exec of etcd, which silently turns
# a relative KUBEBUILDER_ASSETS into "no such file or directory".
ASSETS=$(setup-envtest use "$ENVTEST_K8S_VERSION" --bin-dir "$(pwd)/bin" -p path)

# Skip the e2e suite — needs Kind + KWOK, runs via dev/tools/test-e2e.
mapfile -t PACKAGES < <(go list ./... | grep -v '/test/e2e$')

KUBEBUILDER_ASSETS="$ASSETS" exec go test -race -timeout 10m \
  -coverprofile=coverage.out -covermode=atomic \
  "${PACKAGES[@]}"
